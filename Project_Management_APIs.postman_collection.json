            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{projectId}}\",\n  \"name\": \"Mobile App\",\n  \"description\": \"Develop the iOS and Android companion app.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", ":id"],
              "variable": [
                { "key": "id", "value": "{{projectId}}" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects", ":id"],
              "variable": [
                { "key": "id", "value": "{{projectId}}" }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
