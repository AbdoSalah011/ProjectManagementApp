              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects"],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "description": "Returns a paginated list of projects. Admins see all projects; members see only their own."
          },
          "response": []
        },
