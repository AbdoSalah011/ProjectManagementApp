{
  "info": {
    "_postman_id": "402d6ec8-2a69-4be0-a64f-473b9008a49b",
    "name": "Project Management APIs",
    "description": "Project & Task Management API — Clean Architecture (.NET 9)\n\n## Setup\n1. Set the `baseUrl` collection variable (defaults to https://localhost:7070).\n2. Run **Auth > register** to create a user, then **Auth > login**.\n3. The login request automatically stores the returned access and refresh tokens into the `accessToken` / `refreshToken` collection variables via its test script — all subsequent requests reuse `{{accessToken}}` automatically.\n4. Use **Auth > refreshToken** once the access token expires to obtain a new pair without logging in again.\n\nNo credentials, tokens, or environment-specific IDs are hardcoded in this collection — everything flows through variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "45578686"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:7070",
      "type": "string"
    },
    {
      "key": "apiVersion",
      "value": "v1",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userEmail",
      "value": "user@example.com",
      "type": "string"
    },
    {
      "key": "userPassword",
      "value": "ChangeMe@123",
      "type": "string"
    },
    {
      "key": "projectId",
      "value": "",
      "type": "string"
    },
    {
      "key": "taskId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"isAdmin\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "register"]
            },
            "description": "Creates a new user account. Update `userEmail` / `userPassword` collection variables before running, or override inline."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    const data = body.data ?? body;",
                  "    if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "login"]
            },
            "description": "Authenticates the user and stores the returned access/refresh tokens into collection variables for use by every other request in this collection."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    const data = body.data ?? body;",
                  "    if (data.accessToken) pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/auth/refreshtoken",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "auth", "refreshtoken"]
            },
            "description": "Exchanges a valid refresh token for a new access/refresh token pair."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    const data = body.data ?? body;",
                  "    if (data.id) pm.collectionVariables.set('projectId', data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Marketing Campaign\",\n  \"description\": \"Q3 social media and email marketing push.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/projects",
              "host": ["{{baseUrl}}"],
              "path": ["api", "{{apiVersion}}", "projects"]
            },
            "description": "Creates a new project owned by the authenticated user. Stores the new project's id into the `projectId` collection variable."
          },
          "response": []
        },
        {
